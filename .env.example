# ─── 必填 ────────────────────────────────────────────────────────────────────

# 配置器登录密码（默认 123456，请修改）
ADMIN_PASSWORD=123456

# 客户端访问本代理所用的 API Key（可逗号分隔多个）
MASTER_API_KEY=sk-your-secret-key

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ─── 视觉中间件（可选）────────────────────────────────────────────────────────
# 默认使用阿里云 Qwen，只需填写 VISION_API_KEY 即可启用
# 申请地址：https://dashscope.console.aliyun.com/

VISION_API_KEY=sk-your-dashscope-key

# 也可以换成其他 OpenAI 兼容的视觉模型：
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini

# 默认视觉模型（已内置，无需填写）：
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_MODEL=qwen3.6-flash

# ─── 联网搜索（可选）─────────────────────────────────────────────────────────
# 申请地址：https://tavily.com

# TAVILY_API_KEY=tvly-your-key

# ─── 高级选项（按需修改，通常保持默认即可）──────────────────────────────────

# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash
# VISION_MAX_IMAGES=5
# WEB_SEARCH_PROVIDER=tavily
# PORT=8000
# LOG_LEVEL=INFO
