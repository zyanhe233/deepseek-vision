# Required
# Single key: MASTER_API_KEY=sk-your-secret-key
# Multiple keys (comma-separated): MASTER_API_KEY=sk-key1,sk-key2
MASTER_API_KEY=sk-your-secret-key

# DeepSeek upstream (Anthropic-compatible endpoint)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# Expose these model IDs to clients (comma-separated client-id:upstream-id pairs,
# or just names when client-id == upstream-id)
# Example: deepseek-chat,deepseek-reasoner
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# Optional: add a second Anthropic-compatible upstream (e.g. any OpenAI-proxy
# that speaks the Anthropic Messages API). Leave unset to disable.
# EXTRA_BACKEND_NAME=my-upstream
# EXTRA_BACKEND_BASE_URL=https://your-upstream.example.com
# EXTRA_BACKEND_API_KEY=sk-xxx
# EXTRA_BACKEND_MODELS=model-a,model-b

# Vision: any OpenAI-compatible vision endpoint
# Used to describe images before forwarding to text-only DeepSeek models.
# Leave unset to disable vision middleware (image blocks are passed through as-is).
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=sk-xxx
# VISION_MODEL=gpt-4o-mini
# VISION_PROMPT=Describe this image in detail. Be specific about text, objects, layout, and colors.

# Web Search (Tavily or Brave)
WEB_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=tvly-your-key
# BRAVE_API_KEY=BSA-your-key
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_DEFAULT_MAX_USES=3

# Web Fetch
WEB_FETCH_DEFAULT_MAX_USES=5
WEB_FETCH_DEFAULT_MAX_CONTENT_TOKENS=100000

# Server
PORT=8000
LOG_LEVEL=INFO

# Streaming
STREAM_PING_INTERVAL_SEC=10
STREAM_GAP_WARN_SEC=10

# Slow-request diagnostic dumps
SLOW_REQUEST_THRESHOLD_MS=20000
SLOW_REQUEST_LOG_DIR=logs/slow_requests
SLOW_REQUEST_RETENTION_DAYS=30
